# Security headers for the DEPLOYED site. NOTE: the Content-Security-Policy is
# injected as a <meta> tag at BUILD time (see vite.config.ts) instead of here,
# because `netlify dev` applies _headers to the Vite dev server and a strict
# script-src breaks Vite's React preamble. X-Frame-Options below covers framing
# (the one CSP directive — frame-ancestors — that a meta tag can't express).
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
