VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Firebase Cloud Messaging (push notifications) ──────────────────────────────
# Client web config (public, safe to expose). From Firebase console → Project
# settings → your web app. Leave unset to disable push in the client.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
# Web Push certificate key pair (Cloud Messaging → Web configuration → VAPID).
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key

# Server send credential: the FULL service-account JSON on one line (Project
# settings → Service accounts → Generate new private key). Server-only secret.
FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
