{
  "name": "htms-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Haulage Transaction Management System — Ministry of Energy and Green Transition",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.functions.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:gen": "tsx supabase/seed/generate_seed.ts",
    "audit": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "firebase": "^12.15.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=20.19"
  }
}
